# Copy values into the current shell; do not place funded private keys in files.
CHIADO_RPC_URL=https://rpc.chiado.gnosis.gateway.fm
CHIADO_DEPLOYER_PRIVATE_KEY=0xREPLACE_WITH_A_NEW_CHIADO_ONLY_KEY
EVIDENCE_VERIFIER_PRIVATE_KEY=0xREPLACE_WITH_A_DIFFERENT_CHIADO_ONLY_KEY
EVIDENCE_VERIFIER_ADDRESS=0xADDRESS_DERIVED_FROM_VERIFIER_KEY
PENALTY_TREASURY_ADDRESS=0xYOUR_TESTNET_TREASURY
KEYPER_SET_FILE=runtime/keyper-set.json
# BOND_WEI is read by scripts/deploy.ts (BondedKeyperSlasher, no reward
# split); it defaults to 0.001 ETH on any non-local network if unset.
BOND_WEI=1000000000000000

# The two variables below are read only by scripts/deploy-rewarded.ts,
# which deploys the separate, additive BondedKeyperSlasherRewarded contract
# (see that contract's doc-comment). CALLER_REWARD_WEI must stay
# comfortably above the worst-case observed slashEarlyShare gas cost
# (108,629 gas @ 10,000,000,007 wei/gas on Chiado ~= 1.0863e15 wei; see
# results/slashing-chiado.json) so an unsubsidized caller is actually paid
# to enforce, not merely able to. BOND_WEI_REWARDED must exceed
# CALLER_REWARD_WEI so a positive amount still reaches the treasury.
CALLER_REWARD_WEI=10000000000000000
BOND_WEI_REWARDED=20000000000000000
